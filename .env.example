# ============================================
# Environment Variables Configuration
# ============================================
# Copy this file to .env and update the values

# ============================================
# DATABASE CONNECTION
# ============================================

# For LOCAL development with Docker PostgreSQL (RECOMMENDED):
DATABASE_URL=postgresql://postgres:password123@localhost:5432/job_tracker

# For LOCAL development with native PostgreSQL:
# DATABASE_URL=postgresql://youruser:yourpassword@localhost:5432/job_tracker

# For PRODUCTION (any cloud PostgreSQL database):
# DATABASE_URL=postgresql://user:password@host:5432/database

# ============================================
# SERVER CONFIGURATION
# ============================================

# Backend server port (use 3001 for local, 3000 for production)
# Note: React dev server uses port 3000, so backend should use different port locally
PORT=3001

# Environment mode
NODE_ENV=development

# ============================================
# AUTHENTICATION (Optional - only for production)
# ============================================
# Leave commented out for local development
# Uncomment and set for production deployments

# AUTH_USERNAME=admin
# AUTH_PASSWORD=your_secure_password

# ============================================
# GOOGLE DRIVE API (Optional - for file attachments)
# ============================================
# Leave commented out unless you need Google Drive integration

# GOOGLE_CLIENT_ID=your_client_id
# GOOGLE_CLIENT_SECRET=your_client_secret
# GOOGLE_REDIRECT_URI=http://localhost:3000/auth/google/callback
