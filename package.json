{
  "name": "job-tracker",
  "version": "1.0.0",
  "description": "Job application tracker with Indeed and LinkedIn support",
  "main": "server/index.js",
  "scripts": {
    "start": "node server/index.js",
    "dev": "nodemon server/index.js",
    "build": "npm run build:client",
